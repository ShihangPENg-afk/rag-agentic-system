# 模板文件：仅放占位符，真实 Key 请写入 .env（不要改本文件）
# 首次初始化: make env-init
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI-compatible endpoint for DashScope
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型名称，可根据需要调整
MODEL_NAME=qwen-plus

# PostgreSQL（混合持久化元数据 / 问答日志）
POSTGRES_USER=ragagent
POSTGRES_PASSWORD=ragagent_secret
POSTGRES_DB=ragagent
# 本地直连 Postgres 时使用 localhost；Docker Compose 内由 compose 覆盖为 postgres 主机名
DATABASE_URL=postgresql+psycopg2://ragagent:ragagent_secret@localhost:5432/ragagent

HEALTH_API_URL=http://127.0.0.1:8010